# Rename this file to .env.local and fill in your values

# Email contact (replace with your email)
NEXT_PUBLIC_EMAIL=your.email@example.com

# Social profiles (optional)
NEXT_PUBLIC_LINKEDIN=https://linkedin.com/in/yourprofile
NEXT_PUBLIC_GITHUB=https://github.com/yourprofile

# Analytics (optional)
NEXT_PUBLIC_GA_ID=your_google_analytics_id

# Optional: Contact form backend (if you add a backend service)
# NEXT_PUBLIC_API_URL=https://api.yoursite.com
